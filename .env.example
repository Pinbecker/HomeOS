# ============================================================
# HomeApp — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# ============================================================

# --- Application ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com
BETTER_AUTH_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Hearth

# Used to sign session cookies and tokens — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-64-byte-random-hex-string

# --- Database ---
# Path inside the container (mapped to Docker volume)
DATABASE_URL=/data/db/homeapp.db

# Household ID — generated by the seed script (pnpm db:seed)
# Copy the value printed by the seed script here
HOUSEHOLD_ID=

# --- Email (required for reminders and notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Hearth <your-email@gmail.com>"

# --- Calendar Integration (Phase 3) ---
# Apple ID and app-specific password (not your main Apple password)
# Generate at: appleid.apple.com > Sign-In and Security > App-Specific Passwords
APPLE_CALDAV_USER=your-apple-id@icloud.com
APPLE_CALDAV_APP_PASSWORD=
# The CalDAV URL for your shared calendar
APPLE_CALENDAR_URL=https://caldav.icloud.com/

# --- OneDrive / Microsoft Graph (Phase 4 - film library) ---
# Register an app at portal.azure.com > App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
# Comma-separated folder paths to scan for films
ONEDRIVE_FILM_FOLDERS=/Films,/Movies,/Films/4K

# --- TMDB (Phase 4 - film metadata) ---
# Free API key at: themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_API_BASE=https://api.themoviedb.org/3

# --- AI / Voice (Phase 7) ---
OPENAI_API_KEY=
# or use Claude API for classification
ANTHROPIC_API_KEY=

# --- Backups ---
# How many hourly backups to retain
BACKUP_RETENTION_HOURS=168
# How many daily backups to retain
BACKUP_RETENTION_DAYS=28

# Optional: rclone remote for off-site backups (configure rclone separately)
# e.g., RCLONE_REMOTE=r2 and RCLONE_BUCKET=my-homeapp-backups
RCLONE_REMOTE=
RCLONE_BUCKET=

# --- Uptime Kuma (optional monitoring) ---
# If using Uptime Kuma, push URL for heartbeat
UPTIME_KUMA_PUSH_URL=
