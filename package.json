{
  "name": "homeapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel dev:server dev:web",
    "dev:web": "pnpm --filter @homeos/web dev",
    "dev:server": "pnpm --filter @homeos/server dev",
    "build": "pnpm --filter @homeos/web build && pnpm --filter @homeos/server build",
    "build:web": "pnpm --filter @homeos/web build",
    "build:server": "pnpm --filter @homeos/server build",
    "lint": "pnpm --filter @homeos/web lint && pnpm --filter @homeos/server lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.1",
    "postcss": "^8",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
